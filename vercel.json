{
  "version": 2,
  "builds": [
    {
      "src": "carParts-project/package.json",
      "use": "@vercel/static",
      "config": {
        "distDir": "carParts-project/dist/car-parts-project/browser"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/carParts-project/dist/car-parts-project/browser/index.html"
    }
  ]
}
